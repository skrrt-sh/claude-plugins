{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skrrt.sh/schemas/squad/child-return/v1",
  "title": "Squad Child Return",
  "description": "The structured summary every squad child subagent must return before /spawn cherry-picks its commits.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "return_shape",
    "task_id",
    "status",
    "summary",
    "touched_files",
    "commits",
    "tests_run",
    "blockers",
    "merge_recommendation"
  ],
  "properties": {
    "return_shape": { "const": "squad.child-return.v1" },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "status": { "enum": ["done", "blocked", "failed"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 900 },
    "touched_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change", "bytes_delta"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "change": { "enum": ["added", "modified", "deleted"] },
          "bytes_delta": { "type": "integer" }
        }
      }
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha", "subject"],
        "properties": {
          "sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
          "subject": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "passed": { "type": "integer", "minimum": 0 },
          "failed": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "enum": ["missing-dep", "conflict", "spec-unclear", "validation-failed"]
          },
          "detail": { "type": "string", "minLength": 1 }
        }
      }
    },
    "merge_recommendation": { "enum": ["cherry-pick", "squash", "abort"] },
    "notes_for_orchestrator": { "type": "string", "maxLength": 400 }
  }
}
