{
  "permissions": {
    "allow": [
      "Bash(git worktree list:*)",
      "Bash(git worktree prune:*)",
      "Bash(git branch --list squad/*:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git log --oneline:*)",
      "Bash(git diff --name-only:*)",
      "Bash(git diff --stat:*)",
      "Bash(git status --short:*)",
      "Bash(jq:*)",
      "Bash(ajv validate:*)"
    ],
    "ask": [
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git cherry-pick --abort:*)",
      "Bash(git cherry-pick --continue:*)",
      "Bash(git switch -c squad/*:*)",
      "Bash(git switch squad/*:*)",
      "Bash(git branch -D squad/*:*)",
      "Bash(git update-ref refs/squad-incoming/*:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean:*)",
      "Bash(git commit --amend:*)",
      "Bash(git rebase -i:*)",
      "Bash(git worktree remove --force:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "SQUAD_TASK_DIR": "~/.claude/tasks",
    "SQUAD_MAX_PARALLEL": "4"
  }
}
