{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skrrt.sh/schemas/squad/task-manifest/v1",
  "title": "Squad Task Manifest",
  "description": "Output of /decompose; input to /worktree and /spawn. Describes a parallel/pipelined multi-subagent job.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "run_id",
    "goal",
    "base_ref",
    "pattern",
    "tasks",
    "created_at",
    "created_by"
  ],
  "properties": {
    "manifest_version": { "const": "1" },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 80
    },
    "goal": { "type": "string", "minLength": 1 },
    "base_ref": { "type": "string", "minLength": 1 },
    "pattern": { "enum": ["breadth-first", "pipeline", "map-reduce"] },
    "tasks": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/task" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "rationale",
        "target_files",
        "allowed_tools",
        "subagent_type",
        "worktree",
        "validation_command",
        "return_shape",
        "dependencies",
        "merge_order"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "minLength": 2,
          "maxLength": 64
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "rationale": { "type": "string", "minLength": 1 },
        "target_files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/file" }
        },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "subagent_type": { "enum": ["fork", "named"] },
        "named_subagent_profile": { "type": ["string", "null"] },
        "worktree": { "type": "boolean" },
        "worktree_name": { "type": ["string", "null"] },
        "validation_command": { "type": "string", "minLength": 1 },
        "return_shape": { "const": "squad.child-return.v1" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "merge_order": { "type": "integer", "minimum": 1 },
        "estimated_duration_min": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "subagent_type": { "const": "named" } },
            "required": ["subagent_type"]
          },
          "then": {
            "required": ["named_subagent_profile"],
            "properties": {
              "named_subagent_profile": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "worktree": { "const": true } },
            "required": ["worktree"]
          },
          "then": {
            "required": ["worktree_name"],
            "properties": {
              "worktree_name": {
                "type": "string",
                "minLength": 2,
                "maxLength": 64,
                "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
              }
            }
          }
        }
      ]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "read_only"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "read_only": { "type": "boolean" }
      }
    }
  }
}
